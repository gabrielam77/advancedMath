# ─── MongoDB Atlas Data API ──────────────────────────────────────────────────
# 1. Create a free account at https://cloud.mongodb.com
# 2. Create a free M0 cluster
# 3. Go to App Services > Create App > HTTPS Endpoints > Enable Data API
# 4. Copy the App ID and Base URL (ends with /endpoint/data/v1)
# 5. Go to Authentication > API Keys > Create a key with read/write access

REACT_APP_MONGODB_DATA_API_URL=https://data.mongodb-api.com/app/YOUR_APP_ID/endpoint/data/v1
REACT_APP_MONGODB_API_KEY=YOUR_API_KEY_HERE
REACT_APP_MONGODB_DATABASE=mathTutor
REACT_APP_MONGODB_DATA_SOURCE=Cluster0

# ─── Admin Dashboard ─────────────────────────────────────────────────────────
# Password required to access the in-app admin user management panel
REACT_APP_ADMIN_PASSWORD=choose_a_secure_admin_password
